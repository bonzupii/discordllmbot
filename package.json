{
  "name": "discordllmbot-monorepo",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/lnorton89/discordllmbot.git"
  },
  "workspaces": [
    "bot",
    "dashboard",
    "shared",
    "docs"
  ],
  "description": "Monorepo for DiscordLLMBot, API, and Dashboard",
  "type": "module",
  "dependencies": {
    "dotenv": "^16.4.5",
    "pg": "^8.11.3"
  },
  "scripts": {
    "dev": "docker-compose up -d bot db dashboard",
    "dev:build": "docker-compose up -d --build bot db dashboard",
    "dev:down": "docker-compose down",
    "lint": "npm run lint:bot && npm run lint:dashboard && npm run lint:shared",
    "lint:bot": "npm --prefix ./bot run lint",
    "lint:dashboard": "npm --prefix ./dashboard run lint",
    "lint:shared": "npm --prefix ./shared run lint",
    "type-check": "npm run type-check:bot && npm run type-check:dashboard && npm run type-check:shared",
    "type-check:bot": "npm --prefix ./bot run type-check",
    "type-check:dashboard": "npm --prefix ./dashboard run type-check",
    "type-check:shared": "npm --prefix ./shared run type-check",
    "build": "docker-compose build",
    "docs": "npm --prefix ./docs run dev",
    "docs:generate": "npm --prefix ./docs run generate"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0"
  }
}