FROM node:25-alpine

WORKDIR /usr/src/docs

# Copy only package files for dependency installation
COPY docs/package*.json ./
COPY package*.json ../

# Install dependencies
RUN npm install

# Copy scripts and source files needed for doc generation
COPY docs/scripts ./scripts
COPY bot/src ../bot/src
COPY shared ../shared
COPY README.md ../

EXPOSE 5174

# Generate docs at runtime (before dev server) since src/ is a mounted volume
CMD ["sh", "-c", "npm run generate && npm run dev"]
